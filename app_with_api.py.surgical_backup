            .error { background: #fee; color: #c33; }
            .biometric-icon { font-size: 48px; margin: 20px 0; }
            .links { margin-top: 20px; }
            .links a { color: #666; text-decoration: none; margin: 0 10px; font-size: 14px; }
            .links a:hover { text-decoration: underline; }
            .debug { font-family: monospace; font-size: 12px; background: #f5f5f5; padding: 10px; border-radius: 5px; margin-top: 20px; display: none; text-align: left; max-height: 200px; overflow-y: auto; }
        </style>
    </head>
    <body>
        <div class="container">
            <div class="biometric-icon">🔐</div>
            <h2>Biometric Login</h2>
            <p class="subtitle">Use fingerprint, face ID, or Windows Hello</p>
            
            <div id="message" class="message"></div>
            
            <input type="text" id="username" placeholder="Username" value="Baphomet_78">
            
            <button onclick="biometricLogin()">
                <span>🔑</span> Authenticate with Biometrics
            </button>
            
            <div class="links">
                <a href="/admin-login">Password Login</a>
                <a href="/biometric-setup-fixed">Setup Biometrics</a>
            </div>
            
            <div id="debug" class="debug"></div>
            <button onclick="document.getElementById('debug').style.display='none'" style="font-size:12px; margin-top:10px;">Hide Debug</button>
        </div>

        <script>
        function debug(text) {
            const debugDiv = document.getElementById('debug');
            debugDiv.innerHTML += '<div>' + new Date().toLocaleTimeString() + ': ' + text + '</div>';
            debugDiv.style.display = 'block';
        }
        
        async function biometricLogin() {
            const msg = document.getElementById('message');
            const username = document.getElementById('username').value;
            
            msg.style.display = 'none';
            debug('Starting login for ' + username);
            
            if (!username) {
                msg.textContent = 'Please enter username';
                msg.className = 'message error';
                msg.style.display = 'block';
                return;
            }
            
            try {
                // Step 1: Begin login
                debug('Calling /api/biometric/login/begin');
                const beginResponse = await fetch('/api/biometric/login/begin', {
                    method: 'POST',
                    headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify({username: username})
                });
                
                const options = await beginResponse.json();
                debug('Response status: ' + beginResponse.status);
                
                if (!beginResponse.ok) {
                    msg.textContent = options.error || 'No biometric registered for this username';
                    msg.className = 'message error';
                    msg.style.display = 'block';
                    debug('Error: ' + JSON.stringify(options));
                    return;
                }
                
                debug('Received authentication options');
                
                // Prepare options for WebAuthn
                options.challenge = Uint8Array.from(atob(options.challenge), c => c.charCodeAt(0));
                options.allowCredentials.forEach(cred => {
                    cred.id = Uint8Array.from(atob(cred.id), c => c.charCodeAt(0));
                });
                
                // Request biometric authentication
                debug('Requesting biometric authentication...');
                const credential = await navigator.credentials.get({
                    publicKey: options
                });
                
                debug('Biometric credential received');
                
                // Prepare response for server
                const credentialResponse = {
                    id: credential.id,
                    rawId: btoa(String.fromCharCode(...new Uint8Array(credential.rawId))),
                    type: credential.type,
                    response: {
                        authenticatorData: btoa(String.fromCharCode(...new Uint8Array(credential.response.authenticatorData))),
                        clientDataJSON: btoa(String.fromCharCode(...new Uint8Array(credential.response.clientDataJSON))),
                        signature: btoa(String.fromCharCode(...new Uint8Array(credential.response.signature))),
                        userHandle: credential.response.userHandle ? btoa(String.fromCharCode(...new Uint8Array(credential.response.userHandle))) : null
                    }
                };
                
                // Complete authentication with fixed endpoint
                debug('Calling /api/biometric/login/complete-fixed');
                const completeResponse = await fetch('/api/biometric/login/complete-fixed', {
                    method: 'POST',
                    headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify({
                        username: username,
                        credential: credentialResponse
                    })
                });
                
                const result = await completeResponse.json();
                debug('Server response: ' + JSON.stringify(result));
                
                if (result.success) {
                    msg.textContent = 'Login successful! Redirecting...';
                    msg.className = 'message success';
                    msg.style.display = 'block';
                    
                    setTimeout(() => {
                        window.location.href = result.redirect;
                    }, 1000);
                } else {
                    msg.textContent = result.message || 'Login failed';
                    msg.className = 'message error';
                    msg.style.display = 'block';
                }
            } catch (error) {
                msg.textContent = 'Error: ' + error.message;
                msg.className = 'message error';
                msg.style.display = 'block';
                debug('Error: ' + error.toString());
                console.error(error);
            }
        }
        </script>
    </body>
    </html>
