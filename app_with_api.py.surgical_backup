@app.route('/forgot-password', methods=['GET', 'POST'])
def forgot_password():
    if request.method == 'POST':
        try:
            data = request.get_json()
            email = data.get('email', '')
            
            # For security, always return success even if email doesn't match
            if email and email == ADMIN_EMAIL:
                # In a real app, you'd send an email here
                # For now, we'll just log it
                print(f"Password reset requested for {email}")
                # Create a simple token (in production, use itsdangerous)
                token = secrets.token_urlsafe(32)
                reset_link = f"{request.host_url}reset-password/{token}"
                print(f"Reset link: {reset_link}")
            
            return jsonify({'success': True, 'message': 'If email exists, reset instructions sent'})
        except Exception as e:
            return jsonify({'success': False, 'message': str(e)}), 500
    
    # GET request - show form
    return render_template('forgot_password.html')

@app.route('/reset-password/<token>', methods=['GET', 'POST'])
def reset_password(token):
    if request.method == 'POST':
        try:
            data = request.get_json()
            new_password = data.get('password', '')
            
            if len(new_password) < 8:
                return jsonify({'success': False, 'message': 'Password too short'}), 400
            
            # In production, verify token and update password in database
            # For now, update environment variable (temporary solution)
            global ADMIN_PASSWORD_HASH
            ADMIN_PASSWORD_HASH = generate_password_hash(new_password)
            
            return jsonify({'success': True, 'message': 'Password updated successfully'})
        except Exception as e:
            return jsonify({'success': False, 'message': str(e)}), 500
    
    # GET request - show form
    return render_template('reset_password.html', token=token)

