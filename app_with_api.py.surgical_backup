    # Skip API routes
    if path.startswith('api/'):
        return jsonify({"error": "API endpoint not found"}), 404
    
    # Try ui folder first
    if os.path.exists(os.path.join('ui', path)):
        return send_from_directory('ui', path)
    # Then try root
