# Keep these patterns if needed, but exclude the large binary files
!checkpoints/*/repos/*/*.md
!checkpoints/*/repos/*/*.txt
!checkpoints/*/repos/*/*.py
!checkpoints/*/repos/*/*.js
!checkpoints/*/repos/*/*.json

